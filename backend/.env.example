PORT=5000
MONGO_URI=mongodb://localhost:27017/ai_resume_matching
JWT_SECRET=change_this_to_a_long_random_secret_in_production
REDIS_URL=redis://localhost:6379
NLP_SERVICE_URL=http://localhost:8000
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# OAuth providers (set these to enable social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Use your tenant id or keep "common" for multi-tenant Microsoft login
MICROSOFT_TENANT_ID=common

# OAuth callback URLs to configure in provider consoles:
# Google:    http://localhost:5000/api/auth/oauth/google/callback
# GitHub:    http://localhost:5000/api/auth/oauth/github/callback
# Microsoft: http://localhost:5000/api/auth/oauth/microsoft/callback
# Serper API key for real-time Google job search (https://serper.dev/api-key)
# Leave blank to rely on RemoteOK / Adzuna / The Muse APIs only.
SERPER_API_KEY=0d05cb55c3193b939b4aa0832bfccbac427ef8ea

# ScrapingBee API key for direct Indeed scraping (https://www.scrapingbee.com/)
SCRAPINGBEE_API_KEY=JA5M40GQW59TI5UY791EWOWRDNTY47904KH7FVQXO5FNK4Y6Q6DPDSETDFDGISDFV8W9EVLARPN5X7QL
# Optional country code used by ScrapingBee proxy geotargeting (e.g. us, uk, in)
SCRAPINGBEE_COUNTRY_CODE=in
# Optional default location for ScrapingBee Google Jobs searches
GOOGLE_JOBS_LOCATION=IND
# Optional default location for ScrapingBee LinkedIn Jobs searches
LINKEDIN_JOBS_LOCATION=India
